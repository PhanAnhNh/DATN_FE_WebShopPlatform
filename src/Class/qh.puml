@startuml qh
!theme plain
skinparam linetype ortho
skinparam class {
  BackgroundColor #F5F5F5
  BorderColor #333333
  ArrowColor #2E7D32
}
skinparam stereotype {
  BackgroundColor #E8F5E9
  BorderColor #2E7D32
}

' ============================================
' 1. USER MANAGEMENT
' ============================================

class "users" as users {
  + _id : ObjectId <<PK>>
  --
  + username : String <<UK>>
  + email : String <<UK>>
  full_name : String
  phone : String
  gender : String
  dob : Date
  address : String
  avatar_url : String
  cover_url : String
  role : String
  is_active : Boolean
  is_verified : Boolean
  followers_count : Int
  following_count : Int
  posts_count : Int
  shop_id : ObjectId <<FK>>
  default_address_id : ObjectId <<FK>>
  hashed_password : String
  created_at : DateTime
  updated_at : DateTime
  last_login : DateTime
}

class "admins" as admins {
  + _id : ObjectId <<PK>>
  --
  user_id : ObjectId <<FK>>
  permissions : List<String>
  admin_level : Int
}

class "shops" as shops {
  + _id : ObjectId <<PK>>
  --
  name : String
  slug : String <<UK>>
  description : String
  phone : String
  email : String
  address : String
  province : String
  district : String
  ward : String
  logo_url : String
  banner_url : String
  owner_id : ObjectId <<FK>>
  status : String
  is_verified : Boolean
  products_count : Int
  posts_count : Int
  followers_count : Int
  total_orders : Int
  total_revenue : Float
  view_count : Int
  created_at : DateTime
  updated_at : DateTime
}

class "addresses" as addresses {
  + _id : ObjectId <<PK>>
  --
  user_id : ObjectId <<FK>>
  name : String
  phone : String
  street : String
  ward : String
  district : String
  city : String
  country : String
  is_default : Boolean
  address_type : String
  note : String
  created_at : DateTime
  updated_at : DateTime
}

