' ============================================
' RELATIONSHIPS
' ============================================

' User relationships
users ||--o| admins : extends
users ||--o| shops : owns
users ||--o{ addresses : has
users ||--o{ social_posts : creates
users ||--o{ post_comments : writes
users ||--o{ post_likes : gives
users ||--o{ post_shares : shares
users ||--o{ saved_posts : saves
users ||--o{ messages : sends
users ||--o{ messages : receives
users ||--o{ friend_requests : sends
users ||--o{ friend_requests : receives
users ||--o{ follows : follows
users ||--o{ follows : "followed by"
users ||--o{ orders : places
users ||--o{ payments : makes
users ||--o{ returns : requests
users ||--o{ product_reviews : writes
users ||--o{ shop_reviews : writes
users ||--o{ notifications : receives
users ||--o{ reports : creates
users ||--o{ carts : has

' Admin relationships
admins ||--o{ admin_notifications : receives
admins ||--o{ reports : processes

' Shop relationships
shops ||--o{ products : sells
shops ||--o{ shop_reviews : has
shops ||--o{ shipping_units : manages
shops ||--o{ shipping_vouchers : creates
shops ||--o{ vouchers : creates
shops ||--|| shop_settings : has

' Social post relationships
social_posts ||--o{ post_comments : has
social_posts ||--o{ post_likes : receives
social_posts ||--o{ post_shares : receives
social_posts ||--o{ saved_posts : "saved by"
social_posts ||--o| social_posts : "shares"

' Post comment self-reference
post_comments ||--o{ post_comments : "replies to"

' Category self-reference
categories ||--o{ categories : "has parent"

' Product relationships
categories ||--o{ products : "belongs to"
products ||--o{ product_variants : has
products ||--o{ product_reviews : has
products ||--o{ vouchers : "applies to"

' Order relationships
orders ||--|| payments : has
orders ||--o| returns : "may have"
orders ||--o| shipping_units : uses

' Shipping relationships
shipping_units ||--o{ shipping_vouchers : offers

@enduml