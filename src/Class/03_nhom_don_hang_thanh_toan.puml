@startuml
!theme plain
title Nhóm lớp: Đơn hàng, Giỏ hàng, Thanh toán

class Cart {
  + id: ObjectId
  + user_id: ObjectId
  + product_id: ObjectId
  + quantity: int
  + created_at: date
  + updated_at: date
  --
  + add_item(product_id, quantity): void
  + remove_item(product_id): void
  + update_quantity(product_id, quantity): void
  + calculate_total(): float
}

class Order {
  + id: ObjectId
  + order_code: string
  + user_id: ObjectId
  + shop_id: ObjectId
  + total_amount: float
  + shipping_fee: float
  + discount_amount: float
  + final_amount: float
  + status: string
  + payment_method: string
  + payment_status: string
  + shipping_address: string
  + receiver_name: string
  + receiver_phone: string
  + created_at: date
  + updated_at: date
  --
  + calculate_total(): void
  + update_status(status): void
  + cancel(): void
  + confirm_payment(): void
}

class Payment {
  + id: ObjectId
  + order_id: ObjectId
  + amount: float
  + method: string
  + transaction_id: string
  + status: string
  + paid_at: date
  --
  + process_payment(): boolean
  + refund(): boolean
}

class QrPayment {
  + id: ObjectId
  + order_id: ObjectId
  + qr_code_url: string
  + qr_data: string
  + expires_at: date
  + status: string
  --
  + generate_qr(): string
  + check_payment_status(): string
}

class Return {
  + id: ObjectId
  + order_id: ObjectId
  + user_id: ObjectId
  + reason: string
  + images: string
  + status: string
  + refund_amount: float
  + created_at: date
  + updated_at: date
  --
  + approve_return(): void
  + reject_return(reason): void
  + process_refund(): void
}

class ShippingUnit {
  + id: ObjectId
  + name: string
  + unit_price: float
  + unit_amount: float
  + unit_description: string
  + quantity: int
  + status: string
  + unit_created_at: date
  + unit_updated_at: date
  --
  + calculate_shipping_fee(distance): float
  + update_status(order_id, status): void
}

' Quan hệ
User "1" -- "0..*" Cart : has
User "1" -- "0..*" Order : places
Order "1" -- "0..1" Payment : has
Order "1" -- "0..1" QrPayment : generates
Order "1" -- "0..1" Return : may have
Order "1" -- "1" ShippingUnit : uses

@enduml