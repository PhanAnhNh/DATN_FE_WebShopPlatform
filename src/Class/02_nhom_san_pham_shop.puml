@startuml
!theme plain
title Nhóm lớp: Shop và Sản phẩm

class Shop {
  + id: ObjectId
  + name: string
  + description: string
  + address: string
  + banner_url: string
  + images: string
  + phone: string
  + email: string
  + district: string
  + province_name: string
  + ward: string
  + rating: string
  + total_reviews: int
  + status: string
  + updated_at: date
  --
  + update_shop_info(data): void
  + get_products(): List[Product]
  + calculate_rating(): float
}

class Product {
  + id: ObjectId
  + name: string
  + description: string
  + price: float
  + stock: int
  + images: string
  + shop_id: ObjectId
  + category_id: ObjectId
  + status: string
  + language: string
  + theme: string
  + created_at: date
  + updated_at: date
  --
  + reduce_stock(quantity): boolean
  + add_stock(quantity): void
  + is_available(): boolean
}

class ProductVariant {
  + id: ObjectId
  + product_id: ObjectId
  + name: string
  + price: float
  + stock: int
  + image_url: string
  + created_at: date
  + updated_at: date
  --
  + get_variant_by_options(options): ProductVariant
}

class Category {
  + id: ObjectId
  + name: string
  + description: string
  + parent_id: ObjectId
  + image_url: string
  + status: string
  --
  + get_subcategories(): List[Category]
}

class ShopSettings {
  + id: ObjectId
  + shop_id: ObjectId
  + notification_enabled: boolean
  + auto_confirm_order: boolean
  + working_hours: string
  + holiday_mode: boolean
  --
  + toggle_notification(): void
  + set_working_hours(start, end): void
}

' Quan hệ
Shop "1" -- "0..*" Product : sells
Product "1" -- "0..*" ProductVariant : has
Category "1" -- "0..*" Product : contains
Shop "1" -- "1" ShopSettings : configures

@enduml